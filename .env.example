# Copie para .env e preencha (nunca commite .env)

# Obrigatório — Postgres (Render: copie "Internal Database URL" do banco)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Alternativa (se não usar DATABASE_URL):
# DB_HOST=
# DB_PORT=5432
# DB_USER=
# DB_PASSWORD=
# DB_NAME=

NODE_ENV=development
PORT=10000
JWT_SECRET=
